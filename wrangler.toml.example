# ⚠️ 重要说明：此文件仅用于开发环境
#
name = "bookmark-manager"
compatibility_date = "2024-01-01"
pages_build_output_dir = "dist"
#
# D1 数据库配置（必须）
[[d1_databases]]
binding = "DB"
database_name = "bookmark-db"
database_id = "5c58c80e-a5d1-4cbe-ab04-c3a27985e678"  # 替换为你的 D1 数据库 ID

# R2 存储桶配置（用于备份功能，可选）
#
#[[r2_buckets]]
#binding = "BACKUP_BUCKET"
#bucket_name = "bookmark-backups"
#
# KV 命名空间配置（用于登录速率限制，强烈建议）
# 在 Cloudflare Dashboard > Workers & Pages > KV 中创建命名空间
# 然后在 Pages 项目的 Settings > Functions > KV namespace bindings 中添加绑定
# 变量名填 RATE_LIMIT_STORAGE，选择创建的 KV 命名空间
# [[kv_namespaces]]
# binding = "RATE_LIMIT_STORAGE"
# id = "YOUR_KV_NAMESPACE_ID"
#
# 环境变量（必须）
# - ADMIN_USERNAME          # 管理员用户名，用于登录管理后台
# - ADMIN_PASSWORD          # 管理员密码，用于登录管理后台
# - JWT_SECRET              # JWT 密钥，用于生成登录 token，建议使用至少32位的随机字符串
# 
# AI 功能配置（可选，也可以在设置界面中配置）：
# - OPENAI_API_KEY          # OpenAI API Key（必须，如果不在设置中配置）
# - OPENAI_BASE_URL         # API 基础地址（可选，默认 https://api.openai.com/v1）
# - OPENAI_MODEL            # 模型名称（可选，默认 gpt-4o-mini）
# - OPENAI_AUTH_HEADER      # 认证 Header 名称（可选，默认 Authorization）
# - OPENAI_AUTH_PREFIX      # 认证前缀（可选，默认 "Bearer "，留空表示不添加前缀）

